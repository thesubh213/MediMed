<?xml version="1.0" encoding="utf-8"?>
<!-- Configure backup rules for Android 12+ (API 31+) -->
<data-extraction-rules>
    <cloud-backup>
        <exclude path="." /> <!-- Exclude all databases for privacy-first, local-only -->
    </cloud-backup>
    <device-transfer>
        <include path="." /> <!-- Allow direct device-to-device transfers (e.g. migration) -->
    </device-transfer>
</data-extraction-rules>
