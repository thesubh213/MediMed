<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
        Monochrome layer for Material You themed icons.
        Single-color silhouette of the pill + cross emblem.
        The system will tint this with the user's wallpaper color.
    -->

    <!-- Capsule body silhouette (full pill outline) -->
    <path
        android:fillColor="#000000"
        android:pathData="M44,32 a10,10 0,0 1,20 0 L64,66 a10,10 0,0 1,-20 0 Z"/>

    <!-- Divider cut-out (clear the separator) -->
    <path
        android:fillColor="#000000"
        android:fillAlpha="0.0"
        android:pathData="M43,53 h22 v2 h-22 z"/>

    <!-- Medical cross circle -->
    <path
        android:fillColor="#000000"
        android:pathData="M66,40m-8,0a8,8 0,1 1,16 0a8,8 0,1 1,-16 0"/>

    <!-- Cross cut-outs (make the cross visible by being lighter) -->
    <!-- We use the same fill since monochrome is single-color; the system handles theming -->

</vector>
